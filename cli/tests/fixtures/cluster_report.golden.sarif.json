{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "kdocter",
          "information_uri": "https://github.com/AnonJon/kdocter",
          "rules": [
            {
              "id": "missing_secret_dependency_detected",
              "name": "Missing Secret dependency detected",
              "short_description": {
                "text": "Pod failing because secret db-password does not exist"
              }
            },
            {
              "id": "networkpolicy_blocking_traffic",
              "name": "NetworkPolicy blocking traffic",
              "short_description": {
                "text": "NetworkPolicy rules deny expected ingress/egress for selected pods"
              }
            },
            {
              "id": "service_selector_mismatch_detected",
              "name": "Service selector mismatch detected",
              "short_description": {
                "text": "Service selector does not match any pod labels"
              }
            }
          ]
        }
      },
      "results": [
        {
          "rule_id": "missing_secret_dependency_detected",
          "level": "error",
          "message": {
            "text": "Missing Secret dependency detected"
          },
          "locations": [
            {
              "logical_locations": [
                {
                  "name": "Pod/prod/payments-api"
                }
              ]
            }
          ],
          "properties": {
            "confidence": 0.98,
            "root_cause": "Pod failing because secret db-password does not exist",
            "evidence": [
              "Pod/prod/payments-api -> Secret/db-password -> Secret missing source=pod.dependencies"
            ]
          }
        },
        {
          "rule_id": "service_selector_mismatch_detected",
          "level": "warning",
          "message": {
            "text": "Service selector mismatch detected"
          },
          "locations": [
            {
              "logical_locations": [
                {
                  "name": "Service/prod/payments"
                }
              ]
            }
          ],
          "properties": {
            "confidence": 0.9,
            "root_cause": "Service selector does not match any pod labels",
            "evidence": [
              "service=prod/payments selector=[app=payments] has no matched pods"
            ]
          }
        },
        {
          "rule_id": "networkpolicy_blocking_traffic",
          "level": "warning",
          "message": {
            "text": "NetworkPolicy blocking traffic"
          },
          "locations": [
            {
              "logical_locations": [
                {
                  "name": "Pod/prod/payments-api"
                }
              ]
            }
          ],
          "properties": {
            "confidence": 0.8,
            "root_cause": "NetworkPolicy rules deny expected ingress/egress for selected pods",
            "evidence": [
              "NetworkPolicy/prod/deny-all -> Pod/prod/payments-api direction=ingress+egress selector={\"app\": \"payments-api\"} ingress_rules=0 egress_rules=0 ingress_peers=0 egress_peers=0 ingress_ports=0 egress_ports=0 source=spec.podSelector detail=types=[\"Ingress\", \"Egress\"] ingress_rules=0 egress_rules=0 ingress_peers=0 egress_peers=0 ingress_ports=0 egress_ports=0 default_deny_ingress=true default_deny_egress=true"
            ]
          }
        }
      ]
    }
  ]
}
